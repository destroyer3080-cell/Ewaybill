# Copy to .env and edit. mock mode (default) needs ZERO credentials below.

# --- backend selection ---
EWB_API_MODE=mock            # mock | gsp | nic

# --- GSP/ASP backend (generic REST, MasterGST-style) ---
# Sandbox keys: free via MasterGST signup, or ClearTax/Vayana/Adaequare trials.
GSP_BASE_URL=
GSP_CLIENT_ID=
GSP_CLIENT_SECRET=
GSP_GSTIN=
# Created at ewaybillgst.gov.in -> Registration -> For GSP
GSP_EWB_USERNAME=
GSP_EWB_PASSWORD=

# --- NIC direct backend (v1.03) ---
# Sandbox: free, email ewaybill.api.helpdesk@gmail.com from the registered email.
# Production: test-summary report to nicmof@nic.in + 4 static-IP whitelisting,
# then ewaybillgst.gov.in -> Registration -> For API.
NIC_BASE_URL=
NIC_CLIENT_ID=
NIC_CLIENT_SECRET=
NIC_GSTIN=
NIC_USERNAME=
NIC_PASSWORD=
NIC_PUBLIC_KEY_PATH=./nic_public_key.pem

# --- auto-extend watcher ---
AUTO_EXTEND_ENABLED=false
AUTO_CHECK_INTERVAL_SECONDS=60
AUTO_REASON_CODE=99
AUTO_REASON_REMARKS=Transit delay

# --- app ---
APP_PORT=8000
DB_PATH=./ewb.db
SEED_DEMO_DATA=true          # set false in production

# --- TMS sync job (sync_tms.py) ---
# Upserts shipments from the company TMS on invoice_no. Only TMS-owned
# fields (vehicle/route/distance/IOD status) are updated on existing rows;
# EWB validity is never touched by this job. See sync_tms.py --help.
TMS_SYNC_MODE=csv                    # api | csv
# api mode: TMS exposes a REST endpoint returning a JSON array of shipment
# records (or {"shipments": [...]} / {"data": [...]} / {"results": [...]}).
TMS_API_URL=
TMS_API_KEY=                         # sent as `Authorization: Bearer <key>` if set
TMS_API_TIMEOUT_SECONDS=30
# csv mode: drop *.csv exports into TMS_CSV_WATCH_DIR; each run sweeps the
# directory and moves processed files into ARCHIVE_DIR (clean) or
# ERROR_DIR (any row failed) so cron never reprocesses the same file.
TMS_CSV_WATCH_DIR=./tms_incoming
TMS_CSV_ARCHIVE_DIR=./tms_processed
TMS_CSV_ERROR_DIR=./tms_errors
TMS_SYNC_LOCK_PATH=./sync_tms.lock   # prevents overlapping cron runs
